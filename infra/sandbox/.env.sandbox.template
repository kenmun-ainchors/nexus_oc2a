# TKT-0135 — Nexus Sandbox Environment — Credential Template
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: This is a TEMPLATE only.
#   - Copy to .env.sandbox and fill in values before use
#   - .env.sandbox is in .gitignore — NEVER commit with real values
#   - NEVER use prod secrets here — sandbox-only credentials ONLY
#   - Source: .env.sandbox ONLY — no host keychain, no prod secrets (TKT-0135)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Sandbox Ports (Colima port-forward) ─────────────────────────────────────
SANDBOX_PORT=3131
SANDBOX_MINIO_PORT=9131
SANDBOX_MINIO_CONSOLE_PORT=9132

# ─── MinIO Sandbox Credentials ───────────────────────────────────────────────
# Use simple demo credentials — NOT prod MinIO credentials
SANDBOX_MINIO_USER=sandbox-admin
SANDBOX_MINIO_PASSWORD=REPLACE_WITH_DEMO_PASSWORD_ONLY

# ─── OpenClaw Sandbox Config ─────────────────────────────────────────────────
# Sandbox-specific OpenClaw gateway secret — NOT prod gateway secret
OPENCLAW_GATEWAY_SECRET=REPLACE_WITH_SANDBOX_ONLY_SECRET

# ─── LLM Routing (Option B — route to host Ollama via Docker bridge) ─────────
# Uses host OC1 Ollama endpoint — no separate API key required
OLLAMA_BASE_URL=http://host.docker.internal:11434
SANDBOX_DEFAULT_MODEL=ollama/kimi-k2.6:cloud

# ─── Demo Agent Config ────────────────────────────────────────────────────────
DEMO_AGENT_MINI_YODA_ENABLED=true
DEMO_AGENT_ARIA_ENABLED=true

# ─── Sandbox Identity ────────────────────────────────────────────────────────
OPENCLAW_INSTANCE_NAME=nexus-sandbox
OPENCLAW_ENV=sandbox

# ─────────────────────────────────────────────────────────────────────────────
# Checklist before use:
#   [ ] Replaced all REPLACE_WITH_* values
#   [ ] Confirmed no prod secrets included
#   [ ] Confirmed .env.sandbox is NOT committed to git
#   [ ] Confirmed spend limit set on sandbox API key
# ─────────────────────────────────────────────────────────────────────────────
